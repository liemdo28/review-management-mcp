# Yelp Configuration
# Get your API key from: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key_here

# Find your business ID in the Yelp business URL
# Example: https://www.yelp.com/biz/raw-sushi-bar-city -> raw-sushi-bar-city
YELP_BUSINESS_ID_RAW_SUSHI=your_raw_sushi_business_id
YELP_BUSINESS_ID_BAKUDAN=your_bakudan_ramen_business_id

# Google Business Profile Configuration
# Set up OAuth 2.0 at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Find your location IDs using the Google My Business API
# Format: accounts/{account_id}/locations/{location_id}
GOOGLE_LOCATION_ID_RAW_SUSHI=accounts/123456789/locations/987654321
GOOGLE_LOCATION_ID_BAKUDAN=accounts/123456789/locations/123456789
